            }
          },
          "response": []
        },
        {
          "name": "Add New Book",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Verify Title\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.title).to.eql(\"The Hobbit\");",
                  "});",
                  "// Save newly created book ID to an environment variable for later edits/deletes",
                  "pm.environment.set(\"new_book_id\", pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"The Hobbit\",\n    \"author\": \"J.R.R. Tolkien\",\n    \"published_year\": 1937\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:5000/books",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "5000",
              "path": ["books"]
            }
          },
          "response": []
        },
        {
          "name": "Update Book",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Verify Updated Title\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.title).to.eql(\"The Hobbit: An Unexpected Journey\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"The Hobbit: An Unexpected Journey\",\n    \"published_year\": 2012\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:5000/books/{{new_book_id}}",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "5000",
              "path": ["books", "{{new_book_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Book",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Verify Success Message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.eql(\"Book deleted successfully\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://127.0.0.1:5000/books/{{new_book_id}}",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "5000",
              "path": ["books", "{{new_book_id}}"]
            }
          },
          "response": []
        }
      ]
